{
  "name": "agentlens-vscode",
  "displayName": "AgentLens",
  "description": "Visualize agent instruction AST trees and evolution timelines from AGENTS.md / CLAUDE.md files",
  "version": "0.1.0",
  "publisher": "agentlens",
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onCommand:agentlens.showAST"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agentlens.showAST",
        "title": "AgentLens: Show AST Visualization"
      }
    ],
    "configuration": {
      "title": "AgentLens",
      "properties": {
        "agentlens.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Path to the Python interpreter to use for the backend server"
        },
        "agentlens.backendPort": {
          "type": "number",
          "default": 8765,
          "description": "Port for the local backend server"
        },
        "agentlens.projectRoot": {
          "type": "string",
          "default": "",
          "description": "Path to the agentlens project root (where src/domain/models.py lives)"
        },
        "agentlens.cacheRoot": {
          "type": "string",
          "default": "",
          "description": "Path to the AST cache directory. If empty, uses ~/.agentlens/"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.84.0",
    "typescript": "^5.3.0"
  }
}
