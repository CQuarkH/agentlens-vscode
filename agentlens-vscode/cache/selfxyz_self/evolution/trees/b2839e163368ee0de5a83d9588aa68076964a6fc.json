                "id": "rule_9",
                "type": "rule",
                "content": {
                  "text": "Ensure Node.js 22.x is installed (see `.nvmrc` for exact version), then:\n  - `nvm use`\n  - `corepack enable && corepack prepare yarn@stable --activate`\n  - Verify: `node -v && yarn -v`",
                  "originalHeader": "Setup"
                },
                "metadata": {
                  "strength": "MUST",
                  "format": "ListItem",
                  "line_start": 17,
                  "line_end": 21
                }
              },
              {
                "id": "rule_10",
                "type": "rule",
                "content": {
                  "text": "Run `yarn install` once before running any other commands. This installs root dependencies and sets up husky hooks.",
                  "originalHeader": "Setup"
                },
                "metadata": {
                  "strength": "MUST",
                  "format": "ListItem",
                  "line_start": 22,
                  "line_end": 22
                }
              },
              {
                "id": "rule_11",
                "type": "rule",
                "content": {
                  "text": "# Fix linting and formatting issues automatically (for packages that support it)\nyarn workspaces foreach -A -p -v --topological-dev --since=HEAD run nice --if-present\n\n# Lint all packages in parallel\nyarn lint\n\n# Build all workspaces except `contracts`\nyarn build\n\n# Compile Solidity contracts (may occasionally throw a Hardhat config error)\nyarn workspace @selfxyz/contracts build\n\n# Run type-checking across the repo\nyarn types",
                  "originalHeader": "Commit Checks"
                },
                "metadata": {
                  "strength": "MUST",
                  "format": "Paragraph",
                  "line_start": 62,
                  "line_end": 76
                }
              },
              {
                "id": "rule_12",
                "type": "rule",
                "content": {
                  "text": "# Run all checks before PR - only on changed workspaces since main\n# Format and lint changed workspaces (workspace-specific scripts first, then fallback to root)\nyarn workspaces foreach -A -p -v --topological-dev --since=origin/main run nice --if-present\n\n# Run global checks across all workspaces\nyarn lint && yarn types && yarn build && yarn test",
                  "originalHeader": "Pre-PR Validation"
                },
                "metadata": {
                  "strength": "MUST",
                  "format": "Paragraph",
                  "line_start": 83,
                  "line_end": 88
                }
