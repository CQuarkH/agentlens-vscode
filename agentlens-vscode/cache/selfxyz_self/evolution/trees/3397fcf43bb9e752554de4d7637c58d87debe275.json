                "id": "rule_1",
                "type": "rule",
                "content": {
                  "text": "This repository is a Yarn v4 monorepo with several workspaces:\n\n- `app` – mobile app (@selfxyz/mobile-app)\n- `circuits` – zk-SNARK circuits (@selfxyz/circuits)\n- `common` – shared utilities (@selfxyz/common)\n- `contracts` – solidity contracts (@selfxyz/contracts)\n- `sdk/core` – core TypeScript SDK (@selfxyz/core)\n- `sdk/qrcode` – qrcode SDK (@selfxyz/qrcode)\n- `packages/mobile-sdk-alpha` – alpha version of the SDK (@selfxyz/mobile-sdk-alpha)\n- `noir` – noir circuits",
                  "originalHeader": "AGENTS Instructions"
                },
                "metadata": {
                  "strength": "MUST",
                  "format": "Paragraph",
                  "line_start": 3,
                  "line_end": 12
                }
              }
            ]
