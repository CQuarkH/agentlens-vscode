          {
            "id": "cat_system_overview",
            "label": "System Overview",
            "type": "label",
            "count": 3,
            "children": [
              {
                "id": "rule_10",
                "type": "rule",
                "content": {
                  "text": "The Antimetal Agent is a Kubernetes controller that connects infrastructure to the Antimetal platform for cloud resource management. It collects K8s resources, monitors system performance, and streams data via gRPC.",
                  "originalHeader": "Project Overview"
                },
                "metadata": {
                  "strength": "SHOULD",
                  "format": "Paragraph",
                  "line_start": 55,
                  "line_end": 55
                }
              },
              {
                "id": "rule_11",
                "type": "rule",
                "content": {
                  "text": "The Antimetal Agent includes a comprehensive performance monitoring system that collects system metrics from /proc and /sys filesystems. Collectors follow a dual-interface pattern (PointCollector for one-shot, ContinuousCollector for streaming) with standardized error handling and testing methodologies.",
                  "originalHeader": "Performance Collectors"
                },
                "metadata": {
                  "strength": "SHOULD",
                  "format": "Paragraph",
                  "line_start": 116,
                  "line_end": 116
                }
              },
              {
                "id": "rule_12",
                "type": "rule",
                "content": {
                  "text": "The Antimetal Agent supports eBPF-based collectors for deep kernel observability using CO-RE (Compile Once - Run Everywhere) technology for portability across kernel versions 4.18+.",
                  "originalHeader": "eBPF Development"
                },
                "metadata": {
                  "strength": "SHOULD",
                  "format": "Paragraph",
                  "line_start": 247,
                  "line_end": 247
                }
              }
            ]
          },
          {
