              {
                "id": "rule_35",
                "type": "rule",
                "content": {
                  "text": "```bash\nnode scripts/agentic/cdp-bridge.mjs list-devices     # List connected devices\nscripts/agentic/app-navigate.sh \"/(tabs)/record\"      # Navigate\nscripts/agentic/app-state.sh state                    # Query state\nscripts/agentic/app-state.sh eval \"__AGENTIC__.startRecording({ sampleRate: 44100, channels: 1 })\"\nscripts/agentic/screenshot.sh my-label                # Screenshot\nscripts/agentic/reload-metro.sh                       # Hot reload after edits\nscripts/agentic/native-logs.sh android|ios            # Kotlin/Swift logs\nscripts/agentic/start-metro.sh                        # Start Metro (:7365)\n```",
                  "originalHeader": "Agentic Validation (CDP Bridge)"
                },
                "metadata": {
                  "strength": "SHOULD",
                  "format": "Paragraph",
                  "line_start": 41,
