          {
            "id": "cat_devops",
            "label": "DevOps",
            "type": "label",
            "count": 8,
            "children": [
              {
                "id": "rule_16",
                "type": "rule",
                "content": {
                  "text": "- \u274c `expo prebuild` from monorepo root \u2014 creates spurious `/app.json` and `/eas.json` at root and contaminates the workspace\n- \u2705 All prebuild/build commands run from `apps/playground/` only",
                  "originalHeader": "EAS / prebuild \u2014 critical rules"
                },
                "metadata": {
                  "strength": "MUST",
                  "format": "ListItem",
                  "line_start": 92,
                  "line_end": 93
                }
              },
              {
                "id": "rule_17",
                "type": "rule",
                "content": {
                  "text": "- \u274c `expo prebuild --clean` manually before a local EAS build \u2014 EAS local builds manage their own temp dir; manual prebuild is only for Xcode/screenshots workflows",
                  "originalHeader": "EAS / prebuild \u2014 critical rules"
                },
                "metadata": {
                  "strength": "MUST",
                  "format": "ListItem",
                  "line_start": 94,
                  "line_end": 94
                }
              },
              {
                "id": "rule_18",
                "type": "rule",
                "content": {
                  "text": "- \u2705 Local builds: `yarn build:ios:production:local` / `yarn build:android:production:local` (both run `eas build --local`)",
                  "originalHeader": "EAS / prebuild \u2014 critical rules"
                },
                "metadata": {
                  "strength": "MUST",
                  "format": "ListItem",
                  "line_start": 95,
                  "line_end": 95
                }
              },
              {
                "id": "rule_19",
                "type": "rule",
                "content": {
                  "text": "- \u2705 Switch ios/ variant via setup scripts only: `yarn setup:development` / `yarn setup:production`",
                  "originalHeader": "EAS / prebuild \u2014 critical rules"
                },
                "metadata": {
                  "strength": "MUST",
                  "format": "ListItem",
                  "line_start": 96,
                  "line_end": 96
                }
              },
              {
                "id": "rule_20",
                "type": "rule",
                "content": {
                  "text": "- \u2705 After accidental production prebuild, restore dev workspace: `git checkout -- apps/playground/ios/`",
                  "originalHeader": "EAS / prebuild \u2014 critical rules"
                },
                "metadata": {
                  "strength": "MUST",
                  "format": "ListItem",
                  "line_start": 97,
                  "line_end": 97
                }
              },
              {
                "id": "rule_21",
                "type": "rule",
                "content": {
                  "text": "- ios/ workspace name reveals current variant: `AudioDevPlayground.*` = dev/preview, `AudioPlayground.*` = production",
                  "originalHeader": "EAS / prebuild \u2014 critical rules"
                },
                "metadata": {
                  "strength": "SHOULD",
