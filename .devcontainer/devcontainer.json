{
  "name": "AgentLens Evaluation Environment",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "postCreateCommand": "python3 -m venv .venv && .venv/bin/pip install -r agentlens-vscode/backend/requirements.txt && code --install-extension agentlens-vscode/agentlens-*.vsix",
  "postAttachCommand": "code agentlens-vscode/samples/cartography-cncf_cartography.md",
  "customizations": {
    "vscode": {
      "settings": {
        "agentlens.cacheRoot": "${containerWorkspaceFolder}/agentlens-vscode/cache",
        "agentlens.projectRoot": "${containerWorkspaceFolder}",
        "agentlens.pythonPath": "${containerWorkspaceFolder}/.venv/bin/python",
        "workbench.startupEditor": "none"
      }
    }
  },
  "forwardPorts": [8765]
}